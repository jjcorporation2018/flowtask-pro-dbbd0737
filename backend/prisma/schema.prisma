// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  picture       String?
  googleId      String?   @unique
  role          String    @default("default") // 'admin', 'default', 'disabled'
  permissions   Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ==========================================
// KUNBAN MODELS
// ==========================================

model Folder {
  id          String    @id @default(uuid())
  name        String
  color       String
  icon        String
  sideImage   String?
  createdAt   DateTime  @default(now())
  archived    Boolean   @default(false)
  trashed     Boolean   @default(false)
  trashedAt   DateTime?
  boards      Board[]
}

model Board {
  id              String    @id @default(uuid())
  folderId        String
  folder          Folder    @relation(fields: [folderId], references: [id], onDelete: Cascade)
  name            String
  backgroundColor String
  backgroundImage String?
  createdAt       DateTime  @default(now())
  archived        Boolean   @default(false)
  trashed         Boolean   @default(false)
  trashedAt       DateTime?
  isFavorite      Boolean   @default(false)
  lists           KanbanList[]
}

model KanbanList {
  id          String    @id @default(uuid())
  boardId     String
  board       Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  title       String
  position    Float
  color       String?
  icon        String?
  archived    Boolean   @default(false)
  trashed     Boolean   @default(false)
  trashedAt   DateTime?
  cards       Card[]
  automations Json?
}

model Label {
  id          String   @id @default(uuid())
  name        String
  color       String
  icon        String?
  cards       CardLabel[]
}

model Card {
  id          String    @id @default(uuid())
  listId      String
  list        KanbanList @relation(fields: [listId], references: [id], onDelete: Cascade)
  title       String
  summary     String?   @db.Text
  description String?   @db.Text
  position    Float
  assignee    String?
  dueDate     DateTime?
  startDate   DateTime?
  estimatedTime Int?
  completed   Boolean   @default(false)
  archived    Boolean   @default(false)
  trashed     Boolean   @default(false)
  trashedAt   DateTime?
  customLink  String?
  pncpId      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  labels      CardLabel[]
  checklist   ChecklistItem[]
  comments    Comment[]
  timeEntries TimeEntry[]
  attachments Attachment[]
  milestones  Milestone[]
  automationUndoAction Json?
}

model CardLabel {
  cardId  String
  labelId String
  card    Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label   Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
}

model ChecklistItem {
  id        String   @id @default(uuid())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  text      String
  completed Boolean  @default(false)
}

model Comment {
  id        String   @id @default(uuid())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  text      String   @db.Text
  author    String
  createdAt DateTime @default(now())
}

model TimeEntry {
  id        String   @id @default(uuid())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  startedAt DateTime
  endedAt   DateTime?
  duration  Int      // seconds
}

model Attachment {
  id        String   @id @default(uuid())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  name      String
  url       String   @db.Text
  type      String
  addedAt   DateTime @default(now())
}

model Milestone {
  id        String   @id @default(uuid())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  title     String
  dueDate   DateTime?
  completed Boolean  @default(false)
}

// ==========================================
// BUDGETS & COMPANIES MODELS
// ==========================================

model MainCompanyProfile {
  id               String   @id @default(uuid())
  isDefault        Boolean  @default(false)
  razaoSocial      String
  nomeFantasia     String
  cnpj             String
  state            String
  porte            String
  lastSynced       DateTime?
  dataSource       String?
  naturezaJuridica String
  cep              String
  logradouro       String
  numero           String
  complemento      String
  bairro           String
  municipio        String
  telefone         String
  email            String
  cnaes            Json?
  taxRegime        String
  simplesAnnexes   Json?
  pis              Float
  cofins           Float
  csll             Float
  irpj             Float
  cpp              Float
  iss              Float
  icms             Float
  ipi              Float
  annexRates       Json?
}

model Company {
  id                           String   @id @default(uuid())
  type                         String
  cnpj                         String
  razao_social                 String
  nome_fantasia                String
  descricao_situacao_cadastral String
  cnae_fiscal_descricao        String
  cep                          String
  uf                           String
  municipio                    String
  bairro                       String
  logradouro                   String
  numero                       String
  complemento                  String
  ddd_telefone_1               String?
  ddd_telefone_2               String?
  email                        String?
  contacts                     Json?
  comments                     String?  @db.Text
  amostra                      Boolean?
  frete                        String?
  mantemOferta                 String?
  areasAtuacao                 Json?
  lastCnpjCheck                DateTime?
  seguroCarga                  Boolean?
  customLink                   String?
  rating                       Float?
  isFavorite                   Boolean  @default(false)
  trashed                      Boolean  @default(false)
  trashedAt                    DateTime?
  createdAt                    DateTime @default(now())
}

model Route {
  id             String   @id @default(uuid())
  name           String
  origin         String
  destination    String
  transporterIds Json
  isFavorite     Boolean  @default(false)
  trashed        Boolean  @default(false)
  trashedAt      DateTime?
  createdAt      DateTime @default(now())
}

model Budget {
  id         String   @id @default(uuid())
  title      String
  type       String
  userId     String?
  status     String
  cardId     String?
  items      Json
  totalValue Float
  trashed    Boolean  @default(false)
  trashedAt  DateTime?
  archived   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  link      String?
  type      String   @default("info")
  userId    String?
}

model CompanyDocument {
  id              String   @id @default(uuid())
  title           String
  type            String
  issueDate       DateTime?
  expirationDate  DateTime
  link            String?  @db.Text
  description     String?  @db.Text
  observations    String?  @db.Text
  whereToIssue    String?  @db.Text
  status          String
  fileData        String?  @db.Text
  fileName        String?
  fileSize        Int?
  companyId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  trashed         Boolean  @default(false)
  trashedAt       DateTime?
  attachments     Json?
}


model EssentialDocument {
  id           String    @id @default(uuid())
  title        String
  description  String?   @db.Text
  attachments  Json?
  trashed      Boolean   @default(false)
  trashedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Certificate {
  id               String    @id @default(uuid())
  type             Json      // Array of strings: ['Produto', 'Serviço']
  suppliedItems    String    @db.Text
  suppliedQuantity String?
  kunbunCardId     String?
  issuingAgency    String
  executionDate    DateTime
  description      String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  trashed          Boolean   @default(false)
  trashedAt        DateTime?
  attachments      CertificateAttachment[]
}

model CertificateAttachment {
  id            String      @id @default(uuid())
  certificateId String
  certificate   Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  fileSlot      String      // 'Atestado', 'NF', etc.
  fileName      String
  fileSize      Int
  fileData      String      @db.Text // Base64
  createdAt     DateTime    @default(now())
}

// ==========================================
// ACCOUNTING MODELS
// ==========================================

model AccountingCategory {
  id        String   @id @default(uuid())
  name      String
  type      String   // 'revenue' | 'expense'
  color     String
  createdAt DateTime @default(now())
}

model BankAccount {
  id        String   @id @default(uuid())
  companyId String
  name      String
  balance   Float
  color     String?
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AccountingEntry {
  id               String   @id @default(uuid())
  companyId        String
  title            String
  description      String?  @db.Text
  amount           Float
  date             DateTime
  dueDate          DateTime?
  type             String   // 'revenue' | 'expense'
  categoryId       String
  status           String   // 'pending' | 'paid' | 'overdue'
  documentNumber   String?
  documentEntity   String?
  documentEntityId String?
  competenceDate   DateTime?
  paymentMethod    String?
  bankAccountId    String?
  notes            String?  @db.Text
  attachments      Json?
  linkedTaxId      String?
  linkedInvoiceId  String?
  trashed          Boolean  @default(false)
  trashedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model RecurringExpense {
  id                String   @id @default(uuid())
  companyId         String
  description       String
  amount            Float
  categoryId        String
  dayOfMonth        Int
  active            Boolean  @default(true)
  lastGeneratedDate DateTime?
  createdAt         DateTime @default(now())
}

model Invoice {
  id             String   @id @default(uuid())
  companyId      String
  number         String
  issueDate      DateTime
  type           String   // 'service' | 'product'
  clientName     String
  clientDocument String
  amount         Float
  status         String   // 'draft' | 'issued' | 'cancelled'
  caminho_danfe  String?
  xmlData        String?  @db.Text
  xmlUrl         String?
  pdfUrl         String?
  trashed        Boolean  @default(false)
  trashedAt      DateTime?
  createdAt      DateTime @default(now())
}

model BankTransaction {
  id             String   @id @default(uuid())
  companyId      String
  date           DateTime
  description    String
  amount         Float
  type           String   // 'credit' | 'debit'
  status         String   // 'pending' | 'reconciled'
  matchedEntryId String?
  createdAt      DateTime @default(now())
}

model TaxObligation {
  id          String   @id @default(uuid())
  companyId   String
  month       String
  name        String
  amount      Float
  dueDate     DateTime
  status      String   // 'pending' | 'paid'
  paymentDate DateTime?
  trashed     Boolean  @default(false)
  trashedAt   DateTime?
  createdAt   DateTime @default(now())
}

model AccountingSettings {
  id                String   @id @default(uuid())
  companyId         String   @unique
  taxRegime         String
  taxRatePercentage Float
  taxRate           Float
  meiActivityType   String?
  nfeApiToken       String?
  nfeEnvironment    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AccountantExport {
  id          String   @id @default(uuid())
  companyId   String
  type        String
  period      String
  fileName    String
  fileContent String   @db.Text
  trashed     Boolean  @default(false)
  trashedAt   DateTime?
  createdAt   DateTime @default(now())
}

// ==========================================
// AUDIT MODELS
// ==========================================

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  userName  String
  action    String
  entity    String
  details   String   @db.Text
  timestamp DateTime @default(now())
}
